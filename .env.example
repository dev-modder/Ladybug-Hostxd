# ────────────────────────────────────────────────────────────────────────────────
#  Ladybug-Mini Multi-Host Platform — Environment Configuration
#  Developer: Dev-Ntando
# ────────────────────────────────────────────────────────────────────────────────

# Port (Render sets this automatically)
PORT=3000

# Your Render service URL (used for self-ping keep-alive)
# Example: https://ladybug-mini.onrender.com
RENDER_URL=https://your-service-name.onrender.com

# Dashboard secret PIN (leave empty to disable authentication)
# Set this to protect your dashboard from unauthorized access
DASHBOARD_PIN=

# ────────────────────────────────────────────────────────────────────────────────
#  DEFAULT BOT SETTINGS (can be overridden per session in dashboard)
# ────────────────────────────────────────────────────────────────────────────────

# Default Bot Name
BOT_NAME=Ladybug Bot Mini

# Default Bot Prefix
PREFIX=.

# Default Timezone
TIMEZONE=Asia/Kolkata

# ────────────────────────────────────────────────────────────────────────────────
#  SERVER SETTINGS
# ────────────────────────────────────────────────────────────────────────────────

# Auto-cleanup interval in minutes (default: 30)
CLEANUP_INTERVAL=30

# Keep-alive ping interval in minutes (default: 14 — keeps Render free tier awake)
PING_INTERVAL=14

# ────────────────────────────────────────────────────────────────────────────────
#  OPTIONAL API KEYS (for bot features)
# ────────────────────────────────────────────────────────────────────────────────

OPENAI_API_KEY=
DEEPAI_API_KEY=
REMOVE_BG_API_KEY=

# ────────────────────────────────────────────────────────────────────────────────
#  MULTI-HOST SESSIONS
# ────────────────────────────────────────────────────────────────────────────────
#  Sessions are now managed through the dashboard!
#  Go to your dashboard URL and click "Add New Session" to:
#  - Add multiple bots with different session IDs
#  - Set owner name and number for each bot
#  - Configure individual bot names and prefixes
#  - Start/Stop/Restart bots independently
# ────────────────────────────────────────────────────────────────────────────────
