# LADYBUGNODES Environment Variables
# Copy this file to .env for local development

# Server Port (default: 3000)
PORT=3000

# Your Render service URL (for keep-alive pings)
RENDER_URL=https://your-service.onrender.com

# Admin credentials (CHANGE THESE!)
ADMIN_USERNAME=devntando
ADMIN_PASSWORD=ntando

# JWT Secret (auto-generated on Render, set manually for local dev)
JWT_SECRET=your-super-secret-key-change-me

# MongoDB Connection String (optional - uses file storage if not provided)
# Get this from MongoDB Atlas: mongodb+srv://user:password@cluster.mongodb.net/dbname
MONGODB_URI=

# Node Environment
NODE_ENV=developme
