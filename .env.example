# ─────────────────────────────────────────────
#  Ladybug-Mini Hosting Platform — Environment
# ─────────────────────────────────────────────

# Port (Render sets this automatically)
PORT=3000

# Your Render service URL (used for self-ping keep-alive)
# Example: https://ladybug-mini.onrender.com
RENDER_URL=https://your-service-name.onrender.com

# WhatsApp Session ID (paste your KnightBot session string here)
SESSION_ID=KnightBot!H4.....

# Bot Owner WhatsApp Number (without + or spaces, e.g. 2637868310191)
OWNER_NUMBER=2637868310191

# Bot Name
BOT_NAME=Ladybug Bot Mini

# Bot Prefix
PREFIX=.

# Timezone
TIMEZONE=Asia/Kolkata

# Optional API Keys
OPENAI_API_KEY=
DEEPAI_API_KEY=
REMOVE_BG_API_KEY=

# Auto-cleanup interval in minutes (default: 30)
CLEANUP_INTERVAL=30

# Keep-alive ping interval in minutes (default: 14 — keeps Render free tier awake)
PING_INTERVAL=14

# Dashboard secret PIN (to protect the status page, leave empty to disable)
DASHBOARD_PIN=
