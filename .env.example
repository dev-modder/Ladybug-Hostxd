# Copy this file to .env and fill in your values

# Your Render.com service URL (for keep-alive pings)
RENDER_URL=https://your-service.onrender.com

# Dashboard admin credentials
ADMIN_USERNAME=devntando
ADMIN_PASSWORD=ntando

# JWT secret (auto-generated on Render, set manually for local dev)
JWT_SECRET=super-secret-random-string-change-me

# Node environment
NODE_ENV=production
